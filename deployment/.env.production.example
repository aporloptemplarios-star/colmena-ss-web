COLMENA_HMAC_SECRET=PENDIENTE_HMAC_SECRET_FUERTE

STRIPE_SECRET_KEY=PENDIENTE_STRIPE_LIVE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=PENDIENTE_STRIPE_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=PENDIENTE_STRIPE_PUBLIC_KEY

DISCORD_BOT_TOKEN=PENDIENTE_DISCORD_BOT_TOKEN
DISCORD_GUILD_ID=PENDIENTE_DISCORD_GUILD_ID
