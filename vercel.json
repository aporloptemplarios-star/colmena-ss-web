{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.colmena-ss.es" }],
      "destination": "https://colmena-ss.es/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "colmena-ss.com" }],
      "destination": "https://colmena-ss.es/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.colmena-ss.com" }],
      "destination": "https://colmena-ss.es/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "colmena-ss.org" }],
      "destination": "https://colmena-ss.es/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.colmena-ss.org" }],
      "destination": "https://colmena-ss.es/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "colmena-ss.store" }],
      "destination": "https://colmena-ss.es/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.colmena-ss.store" }],
      "destination": "https://colmena-ss.es/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/colmena-ss",
      "destination": "/colmena-ss.html"
    },
    {
      "source": "/precios",
      "destination": "/precios.html"
    },
    {
      "source": "/registro",
      "destination": "/registro.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/panel",
      "destination": "/panel.html"
    },
    {
      "source": "/forgot-password",
      "destination": "/forgot-password.html"
    },
    {
      "source": "/reset-password",
      "destination": "/reset-password.html"
    },
    {
      "source": "/checkout/success",
      "destination": "/checkout-success.html"
    },
    {
      "source": "/checkout/cancel",
      "destination": "/checkout-cancel.html"
    }
  ]
}
