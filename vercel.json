{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "web",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/colmena-ss",
      "destination": "/colmena-ss.html"
    },
    {
      "source": "/precios",
      "destination": "/precios.html"
    },
    {
      "source": "/registro",
      "destination": "/registro.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/panel",
      "destination": "/panel.html"
    },
    {
      "source": "/forgot-password",
      "destination": "/forgot-password.html"
    },
    {
      "source": "/reset-password",
      "destination": "/reset-password.html"
    },
    {
      "source": "/checkout/success",
      "destination": "/checkout-success.html"
    },
    {
      "source": "/checkout/cancel",
      "destination": "/checkout-cancel.html"
    }
  ]
}
